# =========================
# Крымская Кровельная
# Итоговый .env.example
# =========================
# Этот файл объединяет минимум, который уже фигурирует в рабочем проекте:
# - Next.js / metadata / sitemap / robots
# - Prisma / PostgreSQL
# - /api/leads
# - amoCRM integration
# - fallback webhook (опционально)
# - external amoCRM OAuth endpoints

# -------------------------
# Базовое приложение
# -------------------------
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# -------------------------
# Prisma / PostgreSQL
# -------------------------
# Для локальной разработки и prisma
DATABASE_URL=postgresql://roof_user:roof_password@localhost:5432/roof_db?schema=public
DIRECT_URL=postgresql://roof_user:roof_password@localhost:5432/roof_db?schema=public

# Если используешь docker-compose с postgres, можешь держать те же значения здесь
POSTGRES_DB=roof_db
POSTGRES_USER=roof_user
POSTGRES_PASSWORD=roof_password
POSTGRES_PORT=5432

# -------------------------
# amoCRM (/api/leads, текущий прямой сценарий)
# -------------------------
AMOCRM_BASE_URL=https://example.amocrm.ru
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_REDIRECT_URI=http://localhost:3000/api/amo/oauth/callback/
AMOCRM_REFRESH_TOKEN=your_refresh_token
AMOCRM_PIPELINE_ID=0
AMOCRM_STATUS_NEW_ID=0
AMOCRM_RESPONSIBLE_USER_ID=0
AMOCRM_EXTERNAL_REDIRECT_URI=http://localhost:3000/api/amo/oauth/callback/

# JSON с реально используемыми custom field IDs в amoCRM
# Пример:
# {"source":111111,"service":222222,"city":333333,"formName":444444,"pagePath":555555,"pageTitle":666666,"referer":777777}
AMOCRM_FIELD_IDS_JSON={}

# -------------------------
# amoCRM external OAuth endpoints
# -------------------------
# Используется для внешней интеграции, где install endpoint получает
# client_id/client_secret динамически от amoCRM.
# Redirect URI должен ТОЧНО совпадать с тем, что указан в amoCRM.
AMOCRM_EXTERNAL_REDIRECT_URI=http://localhost:3000/api/amo/oauth/callback

# Минимальное файловое хранилище install payload + token set.
# Для текущего single-VPS сценария это самый практичный вариант без БД.
AMOCRM_EXTERNAL_INSTALL_STORAGE_PATH=.runtime/amocrm-external.json

# -------------------------
# Fallback webhook (необязательно)
# -------------------------
# Используется только как резервный сценарий, если не хочешь принимать лиды напрямую в amoCRM.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_TOKEN=

# -------------------------
# Прочее / будущее расширение
# -------------------------
# Заполни только если в коде реально появится обработка соответствующих webhook/secret.
LEAD_WEBHOOK_SECRET=
AMOCRM_WEBHOOK_SECRET=